# --- model ---
# Provider: openai | anthropic
MODI_MODEL_PROVIDER=openai

# Model name (must match the provider):
#   openai    → gpt-4o, gpt-4o-mini, o1-mini, ...
#   anthropic → claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-4-5-20251001, ...
MODI_MODEL_NAME=gpt-4o-mini

# API key for the selected provider
#   openai    → sk-...
#   anthropic → sk-ant-...
MODI_MODEL_API_KEY=

# Optional: custom base URL (proxies, Azure OpenAI, self-hosted Anthropic-compatible endpoints)
MODI_MODEL_BASE_URL=

# Retry on transient errors (timeout / rate-limit / 5xx)
MODI_MODEL_RETRY_ATTEMPTS=2
MODI_MODEL_RETRY_BACKOFF=1.5

# Optional fallback (V0.4a): on transient failure after retries, try this provider once
# Leave empty to disable fallback
MODI_MODEL_FALLBACK_PROVIDER=
MODI_MODEL_FALLBACK_NAME=
MODI_MODEL_FALLBACK_API_KEY=
MODI_MODEL_FALLBACK_BASE_URL=

# --- per-agent override (optional) ---
# To use a different model for specific agents, add a `model:` block to the
# agent's YAML frontmatter (no env var needed). Example:
#
#   model:
#     provider: anthropic
#     name: claude-sonnet-4-20250514
#     api_key: ${ANTHROPIC_API_KEY}
#     fallback:
#       provider: openai
#       name: gpt-4o
#       api_key: ${OPENAI_API_KEY}
#
# The ${VAR_NAME} syntax expands environment variables at parse time.
# See docs/architecture/09-model-adapter.md for details.

# --- runtime ---
MODI_PERMISSION_MODE=ask
MODI_MAX_STEPS=20
MODI_REPAIR_BUDGET=3

# --- storage ---
MODI_WORKSPACE_ROOT=.modi/workspace
MODI_WORKSPACE_SNAPSHOT_LIMIT=100
MODI_TRACE_ROOT=
MODI_TRACE_REDACT_KEYS=api_key,authorization,password,secret
MODI_TRACE_PAYLOAD_INLINE_LIMIT_BYTES=2048

# --- loaders ---
MODI_AGENT_PROJECT_DIR=agents
MODI_AGENT_USER_DIR=~/.modi/agents
MODI_SKILL_PROJECT_DIR=skills
MODI_SKILL_USER_DIR=~/.modi/skills

# --- tools ---
MODI_TOOL_TIMEOUT_DEFAULT=30
MODI_TOOL_RESULT_INLINE_LIMIT_BYTES=8192

# --- policy ---
MODI_POLICY_RULE_PACKS=core

# --- memory ---
MODI_MEMORY_ROOT=~/.modi/memory
MODI_MEMORY_PROJECT_KEY=
MODI_MEMORY_TOKEN_BUDGET=2000
MODI_MEMORY_PROJECT_HORIZON_DAYS=90

# --- hooks ---
MODI_HOOK_USER_SETTINGS=~/.modi/settings.json
MODI_HOOK_PROJECT_SETTINGS=.modi/settings.json
MODI_HOOK_TIMEOUT_DEFAULT=10
MODI_HOOK_PASS_ENV=PATH,LANG,LC_ALL
