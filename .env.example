# --- model ---
MODI_MODEL_PROVIDER=openai
MODI_MODEL_NAME=gpt-4o-mini
MODI_MODEL_API_KEY=
MODI_MODEL_BASE_URL=
MODI_MODEL_FALLBACK=
MODI_MODEL_RETRY_ATTEMPTS=2
MODI_MODEL_RETRY_BACKOFF=1.5

# --- runtime ---
MODI_PERMISSION_MODE=ask
MODI_MAX_STEPS=20
MODI_REPAIR_BUDGET=3

# --- storage ---
MODI_WORKSPACE_ROOT=.modi/workspace
MODI_WORKSPACE_SNAPSHOT_LIMIT=100
MODI_TRACE_ROOT=
MODI_TRACE_REDACT_KEYS=api_key,authorization,password,secret
MODI_TRACE_PAYLOAD_INLINE_LIMIT_BYTES=2048

# --- loaders ---
MODI_AGENT_PROJECT_DIR=agents
MODI_AGENT_USER_DIR=~/.modi/agents
MODI_SKILL_PROJECT_DIR=skills
MODI_SKILL_USER_DIR=~/.modi/skills

# --- tools ---
MODI_TOOL_TIMEOUT_DEFAULT=30
MODI_TOOL_RESULT_INLINE_LIMIT_BYTES=8192

# --- policy ---
MODI_POLICY_RULE_PACKS=core

# --- memory ---
MODI_MEMORY_ROOT=~/.modi/memory
MODI_MEMORY_PROJECT_KEY=
MODI_MEMORY_TOKEN_BUDGET=2000
MODI_MEMORY_PROJECT_HORIZON_DAYS=90

# --- hooks ---
MODI_HOOK_USER_SETTINGS=~/.modi/settings.json
MODI_HOOK_PROJECT_SETTINGS=.modi/settings.json
MODI_HOOK_TIMEOUT_DEFAULT=10
MODI_HOOK_PASS_ENV=PATH,LANG,LC_ALL
